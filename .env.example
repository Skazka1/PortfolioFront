# База URL API для axios (без завершающего /).
#
# Вариант А — локально с Vite: один dev-сервер, API через прокси.
#   VITE_BACKEND_URL=/api
#
# Вариант Б — фронт и бэк на разных хостах (без общего reverse proxy):
#   укажите полный URL Laravel API, например:
#   VITE_BACKEND_URL=http://192.168.0.10:8000/api
# На бэкенде в .env добавьте origin фронта в CORS_ALLOWED_ORIGINS (через запятую).
#
VITE_BACKEND_URL=/api
